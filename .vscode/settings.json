{
  //! AI chat agent settings
  "chat.agent.enabled": false, //! Disable agent until we can usefully constrain it
  "chat.detectParticipant.enabled": false, //! Allows "Ask" mode to "escape" ask mode and make edits via `@workspace` participant, often escaping to edit WAY MORE than it should, https://github.com/orgs/community/discussions/153443
  "chat.mcp.autostart": "never", //! Disable MCP autostart until we're actually using it
  "chat.tools.edits.autoApprove": { "**/*": false }, //! Just say "no" to agent auto-approve!
  "chat.tools.global.autoApprove": false, //! Just say "no" to agent auto-approve!
  "chat.tools.terminal.autoApprove": { "/.*/": false }, //! Just say "no" to agent auto-approve!
  "chat.tools.terminal.autoApproveWorkspaceNpmScripts": false, //! Just say "no" to agent auto-approve!
  "chat.tools.terminal.enableAutoApprove": false, //! Just say "no" to agent auto-approve!
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": false, //! Just say "no" to agent auto-approve!
  "chat.tools.urls.autoApprove": { "*": false }, //! Just say "no" to agent auto-approve!
  "inlineChat.enableV2": true, //! Not working in Jupyter notebooks
  "search.searchView.semanticSearchBehavior": "manual", //! VSCode hangs after the final find/replace operation empties the search window, kicking off slow Copilot, possibly fixed //? https://code.visualstudio.com/updates/v1_95#_sort-by-relevance-in-semantic-search-experimental
  "chat.implicitContext.enabled": {
    //! Often we want to ask questions without auto-adding context
    "panel": "never",
    "editing-session": "never"
  },
  //! Terminal
  "terminal.integrated.defaultProfile.windows": "PowerShell", //? Use PowerShell on all platforms, facilitates running template scripts
  "terminal.integrated.defaultProfile.linux": "pwsh",
  "terminal.integrated.defaultProfile.osx": "pwsh",
  //! File excludes
  "files.exclude": {
    "**/__pycache__": true,
    "**/.cache": true,
    "**/.jupyter_cache": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "uv.lock": true,
    "packages/templater-obsidian/**": true //? Obsidian templater
  },
  //! File nesting
  "explorer.sortOrder": "foldersNestsFiles",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "root.mdRt": "*.md, LICENSE",
    "root.tsRt": "package.json, eslint.config.mjs, tsconfig.json",
    "root.confRt": ".*, *.exe, *.json, *.lock, *.ps1, *.toml, *.yml, dvc.*"
  },
  //! File associations
  "files.associations": {
    ".all-contributorsrc": "jsonc",
    ".coveragerc": "ini",
    "*.base": "yaml",
    "*.just": "just",
    "root.*Rt": "markdown"
  },
  "vsicons.associations.files": [
    { "icon": "config", "extensions": ["confRt"] },
    { "icon": "markdown", "extensions": ["mdRt"] },
    { "icon": "typescript", "extensions": ["tsRt"] }
  ],
  //! Git
  "git.allowNoVerifyCommit": true,
  "git.commandsToLog": ["commit", "push"],
  "git.confirmNoVerifyCommit": false,
  "git.diagnosticsCommitHook.enabled": true,
  "git.diagnosticsCommitHook.sources": { "*": "error" },
  //! Line-width
  "git.inputValidation": true,
  "git.inputValidationSubjectLength": 88,
  "git.inputValidationLength": 1e100,
  "editor.wordWrapColumn": 88,
  "editor.rulers": [88],
  "scm.inputMaxLineCount": 50,
  "scm.inputMinLineCount": 3,
  "[scminput]": {
    "editor.rulers": [88]
  },
  //! pytest
  "python.testing.pytestEnabled": true,
  //! Formatting
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.wordWrap": "bounded",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.refactoring.autoSave": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "notebook.insertFinalNewline": false,
  "notebook.formatOnCellExecution": true,
  "notebook.formatOnSave.enabled": true,
  //! Code Actions
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.organizeImports": "always"
  },
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "python.analysis.fixAll": ["source.convertImportFormat", "source.unusedImports"],
  //! TypeScript/JavaScript
  "js/ts.experimental.expandableHover": true,
  "js/ts.implementationsCodeLens.enabled": true,
  "js/ts.implementationsCodeLens.showOnInterfaceMethods": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.preferGoToSourceDefinition": true,
  "js/ts.referencesCodeLens.enabled": true,
  "js/ts.referencesCodeLens.showOnAllFunctions": true,
  "js/ts.suggest.completeFunctionCalls": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsserver.experimental.enableProjectDiagnostics": false, //TODO: Fixed? `enableProjectDiagnostics` currently kinda buggy, need `!node_modules` in Problems filter, but it chugs still. Canary (fixed?): https://github.com/microsoft/TypeScript/issues/36664
  "js/ts.tsserver.watchOptions": "vscode",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "off"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "off"
  },
  //! JSON schemas
  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/renovate-schema.json": true
  },
  //! Extensions
  //* autoDocstring
  "autoDocstring.docstringFormat": "numpy-notypes",
  //* DataWrangler
  "dataWrangler.defaultViewingFilterOptions": "advanced",
  "dataWrangler.enabledFileTypes": {
    "csv": true,
    "jsonl": true,
    "parquet": true,
    "tsv": true,
    "xls": true,
    "xlsx": true
  },
  "dataWrangler.experiments.autoDetectCsvDelimiter": true,
  "dataWrangler.experiments.copilot.enabled": true,
  "dataWrangler.experiments.datatypes.pyspark": true,
  "dataWrangler.experiments.fastCsvParsing": true,
  "dataWrangler.outputRenderer.columnInsights.displayByDefault": true,
  "dataWrangler.outputRenderer.enabled": true,
  "dataWrangler.outputRenderer.enabledTypes": {
    "pandas.core.frame.DataFrame": true
  },
  "dataWrangler.outputRenderer.pagination.defaultSize": 10,
  "dataWrangler.panels.displayOnTabFocus": false,
  "dataWrangler.useRelativePath": true,
  //* Better Comments
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": ".....",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "*",
      "color": "#789359",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "NB:",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "...",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],
  //* GitHub Actions
  "github-actions.workflows.pinned.workflows": [".github/workflows/ci.yml"],
  //* Jupyter Notebooks
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "jupyter.showVariableViewWhenDebugging": true,
  //* Marimo
  "marimo.telemetry": false,
  //* MyST
  "myst.preview.extensions": ["colon_fence", "dollarmath"],
  //* Python
  "python.createEnvironment.contentButton": "hide",
  "python.createEnvironment.trigger": "off",
  "python.terminal.activateEnvInCurrentTerminal": false,
  "python.terminal.activateEnvironment": false,
  //* Pylance
  "editor.inlayHints.enabled": "offUnlessPressed",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoIndent": true,
  "python.analysis.completeFunctionParens": false,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.disableTaggedHints": false,
  "python.analysis.displayEnglishDiagnostics": false,
  "python.analysis.enablePytestSupport": true,
  "python.analysis.enableSyncServer": false,
  "python.analysis.extraCommitChars": true,
  "python.analysis.generateWithTypeAnnotation": true,
  "python.analysis.gotoDefinitionInStringLiteral": true,
  "python.analysis.importFormat": "absolute",
  "python.analysis.includeAliasesFromUserFiles": true,
  "python.analysis.indexing": true,
  "python.analysis.inlayHints.callArgumentNames": "all",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.languageServerMode": "full",
  "python.analysis.logLevel": "Information",
  "python.analysis.persistAllIndices": true,
  "python.analysis.regenerateStdLibIndices": true,
  "python.analysis.reportExtraTelemetry": false,
  "python.analysis.showOnlyDirectDependenciesInAutoImport": false,
  "python.analysis.supportDocstringTemplate": true,
  "python.analysis.supportRestructuredText": true,
  "python.analysis.userFileIndexingLimit": -1,
  "python.languageServer": "Pylance",
  "python.analysis.aiCodeActions": {
    "implementAbstractClasses": true,
    "generateDocstring": true,
    "generateSymbol": true
  },
  "python.analysis.packageIndexDepths": [
    { "name": "", "depth": 16, "includeAllSymbols": true }
  ],
  //* PowerShell
  "powershell.startAutomatically": false,
  "powershell.promptToUpdatePowerShell": false,
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.avoidSemicolonsAsLineTerminators": true,
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.useConstantStrings": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": true,
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  //* Rewrap
  "rewrap.wrappingColumn": 88,
  "rewrap.wholeComment": false,
  //* Sourcery
  "sourcery.codeLens": false,
  "sourcery.suggestFixes": false,
  //* Ty
  "ty.importStrategy": "fromEnvironment",
  "ty.diagnosticMode": "workspace",
  //* vscode-icons
  "workbench.iconTheme": "vscode-icons",
  "vsicons.presets.hideExplorerArrows": true,
  "vsicons.dontShowNewVersionMessage": false,
  //! Filetype extensions
  //* Built-in Markdown support
  //? Doesn't play nicely with All Contributors HTML
  "markdown.validate.referenceLinks.enabled": "ignore",
  //* Markdownlint (MD)
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  //* Prettier (JSON, JSONC, YAML)
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.wordWrap": "off"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "off"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "off"
  },
  "yaml.format.printWidth": 88,
  //* Justfile (JUST)
  "[just]": { "editor.tabSize": 2, "editor.wordWrap": "off" },
  //* ruff (PY, IPYNB)
  "ruff.importStrategy": "fromEnvironment",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.wordWrap": "off"
  },
  "[ipynb]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.wordWrap": "off"
  },
  //* Even Better TOML (TOML)
  "[toml]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.wordWrap": "off"
  },
  "evenBetterToml.taplo.configFile.path": ".taplo.toml",
  //* Automatically synchronized environment variables
  //! Please only update by modifying `env.json` then running `./j.ps1 con` to sync
  "terminal.integrated.env.linux": {
    "COPIER_VERSION": "9.7.1",
    "COVERAGE_CORE": "sysmon",
    "DEV_CI_ENV_FILE": ".dummy-ci-env-file",
    "DEV_CI_OUTPUT_FILE": ".dummy-ci-output-file",
    "DEV_CI_PATH_FILE": ".dummy-ci-path-file",
    "JUPYTER_PLATFORM_DIRS": "1",
    "JUST_COMMAND_COLOR": "purple",
    "JUST_EXPLAIN": "true",
    "JUST_LIST_SUBMODULES": "true",
    "JUST_UNSORTED": "true",
    "JUST_VERSION": "1.41.0",
    "POWERSHELL_YAML_VERSION": "0.4.12",
    "PYDEVD_DISABLE_FILE_VALIDATION": "1",
    "PYTHONIOENCODING": "utf-8:strict",
    "PYTHONPYCACHEPREFIX": ".cache/.pycache",
    "PYTHONUTF8": "1",
    "PYTHONWARNDEFAULTENCODING": "1",
    "PYTHONWARNINGS": "ignore",
    "UV_INSTALL_DIR": ".",
    "UV_NO_MODIFY_PATH": "1",
    "UV_VERSION": "0.10.12"
  },
  //! Please only update by modifying `env.json` then running `./j.ps1 con` to sync
  "terminal.integrated.env.osx": {
    "COPIER_VERSION": "9.7.1",
    "COVERAGE_CORE": "sysmon",
    "DEV_CI_ENV_FILE": ".dummy-ci-env-file",
    "DEV_CI_OUTPUT_FILE": ".dummy-ci-output-file",
    "DEV_CI_PATH_FILE": ".dummy-ci-path-file",
    "JUPYTER_PLATFORM_DIRS": "1",
    "JUST_COMMAND_COLOR": "purple",
    "JUST_EXPLAIN": "true",
    "JUST_LIST_SUBMODULES": "true",
    "JUST_UNSORTED": "true",
    "JUST_VERSION": "1.41.0",
    "POWERSHELL_YAML_VERSION": "0.4.12",
    "PYDEVD_DISABLE_FILE_VALIDATION": "1",
    "PYTHONIOENCODING": "utf-8:strict",
    "PYTHONPYCACHEPREFIX": ".cache/.pycache",
    "PYTHONUTF8": "1",
    "PYTHONWARNDEFAULTENCODING": "1",
    "PYTHONWARNINGS": "ignore",
    "UV_INSTALL_DIR": ".",
    "UV_NO_MODIFY_PATH": "1",
    "UV_VERSION": "0.10.12"
  },
  //! Please only update by modifying `env.json` then running `./j.ps1 con` to sync
  "terminal.integrated.env.windows": {
    "COPIER_VERSION": "9.7.1",
    "COVERAGE_CORE": "sysmon",
    "DEV_CI_ENV_FILE": ".dummy-ci-env-file",
    "DEV_CI_OUTPUT_FILE": ".dummy-ci-output-file",
    "DEV_CI_PATH_FILE": ".dummy-ci-path-file",
    "JUPYTER_PLATFORM_DIRS": "1",
    "JUST_COMMAND_COLOR": "purple",
    "JUST_EXPLAIN": "true",
    "JUST_LIST_SUBMODULES": "true",
    "JUST_UNSORTED": "true",
    "JUST_VERSION": "1.41.0",
    "POWERSHELL_YAML_VERSION": "0.4.12",
    "PYDEVD_DISABLE_FILE_VALIDATION": "1",
    "PYTHONIOENCODING": "utf-8:strict",
    "PYTHONPYCACHEPREFIX": ".cache/.pycache",
    "PYTHONUTF8": "1",
    "PYTHONWARNDEFAULTENCODING": "1",
    "PYTHONWARNINGS": "ignore",
    "UV_INSTALL_DIR": ".",
    "UV_NO_MODIFY_PATH": "1",
    "UV_VERSION": "0.10.12"
  },
  //! Other
  //? Other automatically added settings below
  "": ""
}
